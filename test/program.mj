	void addAllSetHelper(set s, int arr[]) int size; int i;{
		size = arr[0];
		if(size == 1) return;
		i = 1;
		do{
			add(s, arr[i]);
			i++;
		}
		while(i < size);
	}

	void unionHelper(set s, int arr1[], int arr2[]){
		addAllSetHelper(s, arr1);
		addAllSetHelper(s, arr2);
	}

	int dummy(int a){
		return a;
	}
	
	int mapHelper(int arr[]) int sum; int size; int i;{
		size = len(arr);
		do{
			sum = sum + dummy(arr[i]);
			i++;
		}
		while(i < size);
		return sum;
	}
	
	void addAllHelper(set s, int arr[]) int size; int i;
	{
		size = len(arr);
		i = 0;
		do{
			add(s, arr[i]);
			i++;
		}
		while(i < size);
	}
	
